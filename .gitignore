# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.jobs/

# python
__pycache__/
*.pyc
.gstack/
.env*.local

# claude / mcp (contains tokens, session data)
.claude/
.mcp.json
.playwright-mcp/

# screenshots (may contain sensitive info)
*.png
!public/**/*.png
!app/apple-icon.png
!app/icon.png
!app/opengraph-image.png
!app/twitter-image.png
!tests/e2e/**/*-snapshots/**/*.png

# playwright e2e tests
tests/.report/
tests/.results/
tests/fixtures/auth.json
playwright/.cache/
playwright-report/
test-results/

# handoff files (may contain tokens)
HANDOFF.md
.worktrees/
